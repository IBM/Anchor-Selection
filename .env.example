# API Provider Configuration
# Copy this file to .env and fill in your credentials

# ============================================================================
# OpenAI Provider (default)
# ============================================================================
# Get your API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-api-key

# ============================================================================
# Together AI Provider
# ============================================================================
# Get your API key from: https://api.together.xyz/settings/api-keys
# TOGETHER_API_KEY=your-together-api-key

# ============================================================================
# OpenRouter Provider
# ============================================================================
# Get your API key from: https://openrouter.ai/keys
# OPENROUTER_API_KEY=your-openrouter-api-key

# ============================================================================
# Custom OpenAI-compatible Provider
# ============================================================================
# For any OpenAI-compatible API endpoint
# CUSTOM_API_KEY=your-custom-api-key
# CUSTOM_BASE_URL=https://your-api-endpoint.com/v1

# ============================================================================
# Usage Examples:
# ============================================================================
#
# OpenAI (default):
#   python async_run_judges.py --model_name gpt-4o
#
# Together AI:
#   python async_run_judges.py --provider together --model_name meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
#
# OpenRouter:
#   python async_run_judges.py --provider openrouter --model_name anthropic/claude-3.5-sonnet
#
# Custom:
#   python async_run_judges.py --provider custom --model_name your-model-name